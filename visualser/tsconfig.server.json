{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "./dist-server",
    "rootDir": ".",
    "noEmitOnError": true
  },
  "include": ["server/**/*.ts", "src/graph/types.ts"],
  "exclude": ["server/**/*.test.ts"]
}
