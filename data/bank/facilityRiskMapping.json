    },
    {
      "containsAny": ["senior"],
      "lgdCategory": "Senior"
    },
    {
      "containsAny": ["unsecured", "clean"],
      "lgdCategory": "Unsecured"
    },
    {
      "containsAny": ["secured", "hypothecation", "mortgage", "pledge"],
