{
  "canonicalDefaults": {
    "Bills Purchased & Discounted": {
      "tCategory": "CP",
      "lgdCategory": "Senior"
    },
    "Cash Credits, Overdrafts & Loans": {
      "tCategory": "WC",
      "lgdCategory": "Secured"
    },
    "Term Loans": {
      "tCategory": "TermLoan",
      "lgdCategory": "Secured"
    }
  },
  "keywordOverrides": [
    {
      "containsAny": ["subordinated", "tier ii", "tier 2", "lower tier"],
